# ═══════════════════════════════════════════════════════════
#  VARIABLES DE ENTORNO — TCS Dashboard
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env a git.
# ═══════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ──────────────────────────────
# En serverless (Vercel) añade ?connection_limit=1 para evitar
# agotar el pool de conexiones entre invocaciones.
DATABASE_URL="postgresql://usuario:password@localhost:5432/tcs_dashboard?connection_limit=1"

# ── JWT ───────────────────────────────────────────────────
# Genera un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mínimo 32 caracteres. Cambia este valor en producción.
JWT_SECRET="cambia-esto-por-un-secreto-aleatorio-de-al-menos-32-caracteres"

# ── Entorno ───────────────────────────────────────────────
NODE_ENV="development"

# ── Rate limit backend (v2.73 / v2.77) ────────────────────
# Por defecto: in-memory (RATE_LIMIT_BACKEND sin setear o "memory").
# En producción multi-réplica (Vercel, Lambda) setea a "redis" para que
# el contador sea atómico y compartido entre instancias.
#
# Si RATE_LIMIT_BACKEND=redis pero faltan credenciales → fallback silencioso
# a memory + logger.warn (nunca rompe el boot).
#
# RATE_LIMIT_BACKEND="redis"
# UPSTASH_REDIS_REST_URL="https://<tu-instancia>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AX..."

# ── JWT rotation (opcional) ───────────────────────────────
# Durante una rotación de JWT_SECRET, setea JWT_SECRET_PREVIOUS al
# valor anterior para que los tokens ya emitidos sigan siendo válidos
# hasta que expiren. Retira esta variable tras la ventana de gracia.
# JWT_SECRET_PREVIOUS="secreto-anterior"
