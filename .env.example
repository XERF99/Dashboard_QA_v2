# ═══════════════════════════════════════════════════════════
#  VARIABLES DE ENTORNO — TCS Dashboard
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env a git.
# ═══════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ──────────────────────────────
# En serverless (Vercel) añade ?connection_limit=1 para evitar
# agotar el pool de conexiones entre invocaciones.
DATABASE_URL="postgresql://usuario:password@localhost:5432/tcs_dashboard?connection_limit=1"

# ── JWT ───────────────────────────────────────────────────
# Genera un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mínimo 32 caracteres. Cambia este valor en producción.
JWT_SECRET="cambia-esto-por-un-secreto-aleatorio-de-al-menos-32-caracteres"

# ── Entorno ───────────────────────────────────────────────
NODE_ENV="development"
